#!/bin/bash
# ~/bin/switch-wm - Toggle between dwm, hyprland, and xfce
# Usage: switch-wm [dwm|hyprland|xfce]
# Or just: switch-wm (cycles through them)

XINITRC="$HOME/.xinitrc"
WM_FILE="$HOME/.config/current-wm"

# Get current WM
get_current_wm() {
    if [ -f "$WM_FILE" ]; then
        cat "$WM_FILE"
    elif grep -q "exec ~/.local/bin/dwm" "$XINITRC" 2>/dev/null; then
        echo "dwm"
    elif grep -q "exec startxfce4" "$XINITRC" 2>/dev/null; then
        echo "xfce"
    else
        echo "dwm"
    fi
}

# Switch to dwm
switch_to_dwm() {
    echo "dwm" > "$WM_FILE"
    # Ensure xinitrc has dwm
    sed -i 's|^exec startxfce4|exec ~/.local/bin/dwm|' "$XINITRC" 2>/dev/null
    echo "Switched to dwm."
    echo "Run: startx"
}

# Switch to hyprland
switch_to_hyprland() {
    echo "hyprland" > "$WM_FILE"
    echo "Switched to Hyprland."
    echo "Run: start-hyprland (from TTY, NOT startx)"
}

# Switch to xfce
switch_to_xfce() {
    echo "xfce" > "$WM_FILE"
    sed -i 's|^exec ~/.local/bin/dwm|exec startxfce4|' "$XINITRC" 2>/dev/null
    echo "Switched to XFCE."
    echo "Run: startx"
}

# Main logic
current=$(get_current_wm)

case "$1" in
    dwm)
        switch_to_dwm
        ;;
    hyprland|hypr)
        switch_to_hyprland
        ;;
    xfce)
        switch_to_xfce
        ;;
    "")
        # Auto-toggle: dwm -> hyprland -> xfce -> dwm
        case "$current" in
            dwm)
                switch_to_hyprland
                ;;
            hyprland)
                switch_to_xfce
                ;;
            xfce|*)
                switch_to_dwm
                ;;
        esac
        ;;
    *)
        echo "Usage: $0 [dwm|hyprland|xfce]"
        echo "Or run without arguments to cycle"
        echo ""
        echo "Current: $current"
        echo ""
        echo "HOW TO LAUNCH:"
        echo "  dwm      -> startx          (X11)"
        echo "  hyprland -> start-hyprland   (Wayland)"
        echo "  xfce     -> startx           (X11)"
        exit 1
        ;;
esac
