#!/bin/bash
# ~/bin/switch-wm - Toggle between dwm, mangowm, and xfce
# Usage: switch-wm [dwm|mangowm|xfce]
# Or just: switch-wm (cycles through them)

XINITRC="$HOME/.xinitrc"

# Get current WM
get_current_wm() {
    if grep -q "exec ~/.local/bin/dwm" "$XINITRC" 2>/dev/null; then
        echo "dwm"
    elif grep -q "exec startxfce4" "$XINITRC" 2>/dev/null; then
        echo "xfce"
    else
        # Check if mangowm marker exists
        if [ -f ~/.config/mango/config.conf ] && \
           [ -f ~/.config/mango/.active ] 2>/dev/null; then
            echo "mangowm"
        else
            echo "dwm"
        fi
    fi
}

# Backup xinitrc
backup_xinitrc() {
    cp "$XINITRC" "$XINITRC.backup.$(date +%Y%m%d_%H%M%S)" 2>/dev/null || true
}

# Switch to dwm
switch_to_dwm() {
    backup_xinitrc
    # Remove mangowm marker
    rm -f ~/.config/mango/.active 2>/dev/null
    # Set xinitrc to dwm
    sed -i 's|^exec |exec ~/.local/bin/dwm #|' "$XINITRC" 2>/dev/null || \
    echo "exec ~/.local/bin/dwm" >> "$XINITRC"
    echo "Switched to dwm."
    echo "Run: startx"
    notify-send "WM Switch" "Switched to dwm. Run: startx" 2>/dev/null || true
}

# Switch to mangowm  
switch_to_mangowm() {
    # For Wayland compositor - just create a marker file
    touch ~/.config/mango/.active 2>/dev/null
    echo "Switched to MangoWM."
    echo ""
    echo "╔══════════════════════════════════════════════════════════╗"
    echo "║  IMPORTANT: MangoWM is Wayland (NOT X11)                 ║"
    echo "╠══════════════════════════════════════════════════════════╣"
    echo "║  Run: mango (directly from TTY)                          ║"
    echo "║  DO NOT use 'startx' - that only works for X11 WMs      ║"
    echo "╚══════════════════════════════════════════════════════════╝"
    echo ""
    notify-send "WM Switch" "MangoWM: Run 'mango' from TTY (not startx)" 2>/dev/null || true
}

# Switch to xfce
switch_to_xfce() {
    backup_xinitrc
    # Remove mangowm marker
    rm -f ~/.config/mango/.active 2>/dev/null
    sed -i 's|^exec |exec startxfce4 #|' "$XINITRC" 2>/dev/null || \
    echo "exec startxfce4" >> "$XINITRC"
    echo "Switched to XFCE."
    echo "Run: startx"
    notify-send "WM Switch" "Switched to XFCE. Run: startx" 2>/dev/null || true
}

# Main logic
current=$(get_current_wm)

case "$1" in
    dwm)
        switch_to_dwm
        ;;
    mangowm|mango)
        switch_to_mangowm
        ;;
    xfce)
        switch_to_xfce
        ;;
    "")
        # Auto-toggle: dwm -> mangowm -> xfce -> dwm
        case "$current" in
            dwm)
                switch_to_mangowm
                ;;
            mangowm)
                switch_to_xfce
                ;;
            xfce)
                switch_to_dwm
                ;;
        esac
        ;;
    *)
        echo "Usage: $0 [dwm|mangowm|xfce]"
        echo "Or run without arguments to cycle through them"
        echo ""
        echo "Current WM: $current"
        echo ""
        echo "HOW TO LAUNCH:"
        echo "  dwm     -> startx    (from TTY, X11)"
        echo "  mangowm -> mango     (direct from TTY, Wayland - NOT startx!)"
        echo "  xfce    -> startx    (from TTY, X11)"
        exit 1
        ;;
esac
