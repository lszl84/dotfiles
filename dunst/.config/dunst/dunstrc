[global]
    font = Adwaita Mono 10
    corner_radius = 14
    frame_width = 2
    frame_color = "#ffffff"
    separator_color = frame
    origin = top-right
    offset = 7x31
    width = 350
    height = 150
    padding = 12
    horizontal_padding = 14
    gap_size = 4
    icon_position = left
    max_icon_size = 48
    progress_bar_corner_radius = 7
    background = "#2a2a2acc"
    foreground = "#eeeeee"
    highlight = "#ffffff"
    mouse_left_click = close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#2a2a2acc"
    foreground = "#bbbbbb"
    frame_color = "#444444"

[urgency_normal]
    background = "#2a2a2acc"
    foreground = "#eeeeee"
    frame_color = "#ffffff"

[urgency_critical]
    background = "#3a1515cc"
    foreground = "#eeeeee"
    frame_color = "#e05050"
