#!/bin/bash
# brightness up|down [steps]
# Detects which output the cursor is on (DP-* → asdbctl, else → brightnessctl).
# wl-find-cursor returns global layout coordinates (layer surface covers full layout).

set -eu
DIR="${1:-up}"
STEPS="${2:-20}"

cursor_output() {
    local cx cy pos
    pos=$(wl-find-cursor -p 2>/dev/null) || return 1
    [ -z "$pos" ] && return 1
    read -r cx cy <<< "$pos"

    wlr-randr 2>/dev/null | awk -v cx="$cx" -v cy="$cy" '
        /^[^ ]+[-][0-9]/ {
            if (in_block && raw_w > 0) {
                lw = raw_w / s; lh = raw_h / s
                if (cx >= x && cx <= x + lw && cy >= y && cy <= y + lh)
                    { print name; found=1; exit }
            }
            name=$1; in_block=1; raw_w=0; raw_h=0; x=0; y=0; s=1; next
        }
        in_block && /current/ && raw_w==0 { split($1,a,"x"); raw_w=(a[1]+0); raw_h=(a[2]+0) }
        in_block && /Position:/ { split($2,p,","); x=(p[1]+0); y=(p[2]+0) }
        in_block && /Scale:/    { s=($2+0) }
        END {
            if (!found && in_block && raw_w > 0) {
                lw = raw_w / s; lh = raw_h / s
                if (cx >= x && cx <= x + lw && cy >= y && cy <= y + lh)
                    print name
            }
        }
    '
}

geometric_step() {
    local cur="$1" max="$2" min="${3:-1}"
    awk -v cur="$cur" -v max="$max" -v min="$min" -v steps="$STEPS" -v dir="$DIR" '
    BEGIN {
        f = (max / min) ^ (1.0 / steps)
        n = (dir == "up") ? cur * f : cur / f
        n = int(n + 0.5)
        if (dir == "up"   && n <= cur) n = cur + 1
        if (dir == "down" && n >= cur) n = cur - 1
        if (n > max) n = max
        if (n < min) n = min
        print n
    }'
}

OUT=$(cursor_output)

if [ -n "$OUT" ] && [[ "$OUT" =~ ^DP- ]]; then
    CUR=$(asdbctl get 2>/dev/null | grep -oP '[\d.]+' || true)
    if [ -n "$CUR" ]; then
        NEW=$(geometric_step "$CUR" 100)
        asdbctl set "$NEW" >/dev/null 2>&1 || true
    fi
else
    CUR=$(brightnessctl get)
    MAX=$(brightnessctl max)
    NEW=$(geometric_step "$CUR" "$MAX" 1)
    brightnessctl set "$NEW" >/dev/null
fi
