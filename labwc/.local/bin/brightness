#!/bin/bash
# brightness up|down [steps]
# Geometric stepping so each press feels equal to the human eye.
# Factor = (MAX/MIN)^(1/STEPS); each press multiplies/divides by it.
# Forces a minimum 1-raw-unit move so we don't get stuck near the floor.

set -eu

DIR="${1:-up}"
STEPS="${2:-20}"
# MIN_RAW=1 skips raw=0; some panels (this laptop's OLED) misbehave at 0.
MIN_RAW=1

CUR=$(brightnessctl get)
MAX=$(brightnessctl max)

NEW=$(awk -v cur="$CUR" -v max="$MAX" -v min="$MIN_RAW" -v steps="$STEPS" -v dir="$DIR" '
BEGIN {
    f = (max / min) ^ (1.0 / steps)
    n = (dir == "up") ? cur * f : cur / f
    n = int(n + 0.5)
    if (dir == "up"   && n <= cur) n = cur + 1
    if (dir == "down" && n >= cur) n = cur - 1
    if (n > max) n = max
    if (n < min) n = min
    print n
}')

brightnessctl set "$NEW" >/dev/null
