#!/bin/bash
# brightness up|down [steps]
# If cursor is on Apple Studio Display → asdbctl
# Otherwise → brightnessctl (laptop panel)

set -eu
DIR="${1:-up}"
STEPS="${2:-20}"

# --- Get Apple Display logical geometry from wlr-randr ---
# Returns: x y w h (empty if no DP output found)
# wlr-randr blocks have NO blank line between them; we detect header lines.
apple_geometry() {
    wlr-randr 2>/dev/null | awk '
        /^[^ ]+[-][0-9]/ {
            if (in_block && raw_w > 0)
                printf "%.0f %.0f %.0f %.0f\n", x, y, raw_w/s, raw_h/s
            name=$1; in_block=1; raw_w=0; raw_h=0; x=0; y=0; s=1; next
        }
        in_block && /current/ && raw_w==0 { split($1,a,"x"); raw_w=(a[1]+0); raw_h=(a[2]+0) }
        in_block && /Position:/ { split($2,p,","); x=(p[1]+0); y=(p[2]+0) }
        in_block && /Scale:/    { s=($2+0) }
        END {
            if (in_block && raw_w > 0)
                printf "%.0f %.0f %.0f %.0f\n", x, y, raw_w/s, raw_h/s
        }
    '
}

# --- Check if cursor is within given rectangle (logical coords) ---
cursor_in_rect() {
    local gx="$1" gy="$2" gw="$3" gh="$4"
    local cx cy pos
    pos=$(wl-find-cursor -p 2>/dev/null) || return 1
    [ -z "$pos" ] && return 1
    read -r cx cy <<< "$pos"
    # 2px tolerance for sub-pixel rounding at output edges
    [ "$cx" -ge "$((gx - 2))" ] && [ "$cx" -le "$((gx + gw + 2))" ] && \
    [ "$cy" -ge "$((gy - 2))" ] && [ "$cy" -le "$((gy + gh + 2))" ]
}

# --- Geometric stepping ---
geometric_step() {
    local cur="$1" max="$2" min="${3:-1}"
    awk -v cur="$cur" -v max="$max" -v min="$min" -v steps="$STEPS" -v dir="$DIR" '
    BEGIN {
        f = (max / min) ^ (1.0 / steps)
        n = (dir == "up") ? cur * f : cur / f
        n = int(n + 0.5)
        if (dir == "up"   && n <= cur) n = cur + 1
        if (dir == "down" && n >= cur) n = cur - 1
        if (n > max) n = max
        if (n < min) n = min
        print n
    }'
}

# --- Main ---
GEOM=$(apple_geometry)
if [ -n "$GEOM" ] && cursor_in_rect $GEOM; then
    # Apple Studio Display
    CUR=$(asdbctl get 2>/dev/null | grep -oP '[\d.]+' || echo 50)
    NEW=$(geometric_step "$CUR" 100)
    asdbctl set "$NEW" >/dev/null 2>&1
else
    # Laptop panel
    CUR=$(brightnessctl get)
    MAX=$(brightnessctl max)
    NEW=$(geometric_step "$CUR" "$MAX" 1)
    brightnessctl set "$NEW" >/dev/null
fi
