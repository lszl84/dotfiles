#!/bin/bash
# brightness up|down [steps]
# Routes to asdbctl when the focused toplevel is on an external DisplayPort
# output (Apple Studio Display), otherwise brightnessctl on the laptop panel.
# focused-output prints the wl_output name of the activated toplevel.

set -eu
DIR="${1:-up}"
STEPS="${2:-20}"

geometric_step() {
    local cur="$1" max="$2" min="${3:-1}"
    awk -v cur="$cur" -v max="$max" -v min="$min" -v steps="$STEPS" -v dir="$DIR" '
    BEGIN {
        f = (max / min) ^ (1.0 / steps)
        n = (dir == "up") ? cur * f : cur / f
        n = int(n + 0.5)
        if (dir == "up"   && n <= cur) n = cur + 1
        if (dir == "down" && n >= cur) n = cur - 1
        if (n > max) n = max
        if (n < min) n = min
        print n
    }'
}

OUTPUT=$(focused-output 2>/dev/null || true)

if [[ "$OUTPUT" == DP-* ]]; then
    CUR=$(asdbctl get 2>/dev/null | grep -oP '[\d.]+' || true)
    if [ -n "$CUR" ]; then
        NEW=$(geometric_step "$CUR" 100)
        asdbctl set "$NEW" >/dev/null 2>&1 || true
    fi
else
    CUR=$(brightnessctl get)
    MAX=$(brightnessctl max)
    NEW=$(geometric_step "$CUR" "$MAX" 1)
    brightnessctl set "$NEW" >/dev/null
fi
