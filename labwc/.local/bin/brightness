#!/bin/bash
# brightness up|down [steps]
# wl-find-cursor returns "0 0" when cursor is NOT on the active output (DP-2).
# Non-zero → cursor on DP-2 → asdbctl. "0 0" → cursor on laptop → brightnessctl.

set -eu
DIR="${1:-up}"
STEPS="${2:-20}"

geometric_step() {
    local cur="$1" max="$2" min="${3:-1}"
    awk -v cur="$cur" -v max="$max" -v min="$min" -v steps="$STEPS" -v dir="$DIR" '
    BEGIN {
        f = (max / min) ^ (1.0 / steps)
        n = (dir == "up") ? cur * f : cur / f
        n = int(n + 0.5)
        if (dir == "up"   && n <= cur) n = cur + 1
        if (dir == "down" && n >= cur) n = cur - 1
        if (n > max) n = max
        if (n < min) n = min
        print n
    }'
}

POS=$(wl-find-cursor -p 2>/dev/null || true)

if [ "$POS" != "0 0" ] && [ -n "$POS" ]; then
    # Cursor on DP-* (same output as layer surface → Apple display)
    CUR=$(asdbctl get 2>/dev/null | grep -oP '[\d.]+' || true)
    if [ -n "$CUR" ]; then
        NEW=$(geometric_step "$CUR" 100)
        asdbctl set "$NEW" >/dev/null 2>&1 || true
    fi
else
    # Cursor on different output (laptop) or detection failed → brightnessctl
    CUR=$(brightnessctl get)
    MAX=$(brightnessctl max)
    NEW=$(geometric_step "$CUR" "$MAX" 1)
    brightnessctl set "$NEW" >/dev/null
fi
