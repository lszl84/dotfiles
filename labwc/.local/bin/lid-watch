#!/bin/sh
# ~/.local/bin/lid-watch
# Toggle eDP-1 based on lid state. Start from autostart, runs forever.
prev=""
while true; do
    state=$(cat /proc/acpi/button/lid/LID/state 2>/dev/null | awk '{print $2}')
    if [ "$state" != "$prev" ]; then
        if [ "$state" = "closed" ]; then
            wlr-randr --output eDP-1 --off 2>/dev/null
        else
            wlr-randr --output eDP-1 --on 2>/dev/null
        fi
        pkill -x kanshi 2>/dev/null
        setsid kanshi &
        prev="$state"
    fi
    sleep 2
done
