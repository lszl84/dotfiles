#!/bin/bash
# labwc autostart

# Emacs daemon
emacs --daemon &

# SSH agent
ssh-agent -D &

# Terminal server
foot --server &

# Output management
kanshi >/dev/null 2>&1 &

# Status bar
simpbar &

# Idle management
# before-sleep: keep the inhibitor held for 1s after swaylock daemonizes so
# the compositor finishes rendering and the display scans out the lock
# surface BEFORE the framebuffer is frozen by suspend. Without this, on
# resume the display briefly shows the pre-suspend frame (desktop content).
swayidle -w \
  timeout 900 'swaylock -f -c 000000' \
  timeout 3600 'systemctl suspend' \
  before-sleep 'swaylock -f -c 000000; sleep 1' \
  lock 'swaylock -f -c 000000' &

# GTK theme
gsettings set org.gnome.desktop.interface gtk-theme Adwaita-dark
gsettings set org.gnome.desktop.interface color-scheme prefer-dark

# Audio: force ALSA card profile activation
sleep 2 && wpctl set-profile 42 0 && wpctl set-profile 42 1 &

# Set wallpaper
swaybg -i ~/.local/share/wallpapers/earth_oled.png -m fill &
