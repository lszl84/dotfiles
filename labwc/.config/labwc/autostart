#!/bin/bash
# labwc autostart

# Emacs daemon
emacs --daemon &

# SSH agent
ssh-agent -D &

# Terminal server
foot --server &

# Output management
kanshi >/dev/null 2>&1 &

# Status bar
simpbar &

# Idle management
# before-sleep: lock, then turn the display off via wlopm BEFORE suspend
# freezes the framebuffer. Without this, on resume the display briefly
# shows the pre-suspend frame (desktop content) before the lock surface
# composites — a security leak. With the panel off through the suspend/
# resume gap, there is no "last-presented frame" to leak.
# after-resume: turn the panel back on; by then labwc has already
# composited the lock surface, so the panel lights up showing the lock.
swayidle -w \
  timeout 900 'swaylock -f -c 000000' \
  timeout 3600 'systemctl suspend' \
  before-sleep 'swaylock -f -c 000000; wlopm --off "*"' \
  after-resume 'wlopm --on "*"' \
  lock 'swaylock -f -c 000000' &

# GTK theme
gsettings set org.gnome.desktop.interface gtk-theme Adwaita-dark
gsettings set org.gnome.desktop.interface color-scheme prefer-dark

# Audio: force ALSA card profile activation
sleep 2 && wpctl set-profile 42 0 && wpctl set-profile 42 1 &

# Set wallpaper
swaybg -i ~/.local/share/wallpapers/earth_oled.png -m fill &
