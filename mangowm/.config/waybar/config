{
    "layer": "top",
    "position": "top",
    "height": 30,
    "exclusive": true,
    "modules-left": ["dwl/tags", "dwl/window"],
    "modules-center": [],
    "modules-right": ["pulseaudio", "battery", "custom/uptime", "clock"],
    "dwl/tags": {
        "num-tags": 4,
        "tag-labels": ["1", "2", "3", "4"]
    },
    "dwl/window": {
        "format": "{title}",
        "max-length": 50
    },
    "pulseaudio": {
        "format": "vol {volume}%",
        "format-muted": "vol mute",
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
    },
    "battery": {
        "interval": 30,
        "format": "bat {capacity}% ({time})",
        "format-time": "{H}h {m}m left",
        "format-charging": "bat {capacity}% ({time})",
        "format-full": "bat 100%",
        "states": {
            "warning": 20,
            "critical": 10
        }
    },
    "custom/uptime": {
        "exec": "awk '{d=int($1/86400); if(d>=14) printf \"* update & reboot! *\"; else printf \"up %dd\",d}' /proc/uptime",
        "interval": 60,
        "format": "{}"
    },
    "clock": {
        "format": "{:%a, %-d, %H:%M}",
        "tooltip-format": "{:%Y-%m-%d}"
    }
}
